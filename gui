                elIcon(el, "rbxassetid://3926305904", Vector2.new(644,364), Vector2.new(36,36), theme.Accent)
                local lbl = elLabel(el, dname)

                local Arrow = Instance.new("TextLabel")
                Arrow.Parent               = el
