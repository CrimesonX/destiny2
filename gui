        TabBtn.Name                 = tabName.."_Tab"
        TabBtn.Parent               = TabContainer
        TabBtn.BackgroundColor3     = theme.Element
        TabBtn.BackgroundTransparency = 1
        TabBtn.Size                 = UDim2.new(1, 0, 0, 34)
