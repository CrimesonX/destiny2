                Arrow.Text                 = "⌄"
                Arrow.TextColor3           = theme.Accent
                Arrow.TextSize             = 16
                Arrow.ZIndex               = 4

                local Panel = Instance.new("Frame")
                Panel.Parent           = Wrap
                Panel.BackgroundColor3 = theme.Element
                Panel.BorderSizePixel  = 0
                Panel.Position         = UDim2.new(0, 0, 0, 38)
                Panel.Size             = UDim2.new(1, 0, 0, 0)
                Panel.ClipsDescendants = true
                Panel.ZIndex           = 20
                addCorner(Panel, 7)
                addStroke(Panel, theme.Border, 1, 0.0)

                local PanelList = Instance.new("UIListLayout")
                PanelList.Parent    = Panel
                PanelList.SortOrder = Enum.SortOrder.LayoutOrder
                PanelList.Padding   = UDim.new(0, 2)
                addPadding(Panel, 4, 4, 4, 4)

                local function buildOptions(opts)
                    for _, child in pairs(Panel:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    for _, v in ipairs(opts) do
                        local opt = Instance.new("TextButton")
                        opt.Parent               = Panel
                        opt.BackgroundColor3     = theme.Header
                        opt.BackgroundTransparency = 1
                        opt.BorderSizePixel      = 0
                        opt.Size                 = UDim2.new(1, 0, 0, 30)
                        opt.AutoButtonColor      = false
                        opt.Font                 = Enum.Font.Gotham
                        opt.Text                 = "  "..v
                        opt.TextColor3           = theme.Text
                        opt.TextSize             = 13
                        opt.TextXAlignment       = Enum.TextXAlignment.Left
                        opt.ZIndex               = 21
                        addCorner(opt, 5)

                        opt.MouseEnter:Connect(function()
                            tween(opt, {BackgroundTransparency = 0, BackgroundColor3 = theme.Element}, 0.12)
                        end)
                        opt.MouseLeave:Connect(function()
                            tween(opt, {BackgroundTransparency = 1}, 0.12)
                        end)
                        opt.MouseButton1Click:Connect(function()
                            local ms = Players.LocalPlayer:GetMouse()
                            ripple(opt, theme.Accent, ms)
                            lbl.Text = v
                            opened = false
                            -- BUG FIX #9: reset Wrap size when closing via option select
                            tween(Panel, {Size = UDim2.new(1,0,0,0)}, 0.2, Enum.EasingStyle.Quint)
                            tween(Arrow, {Rotation = 0}, 0.2)
                            Wrap.Size = UDim2.new(1, 0, 0, 36)
                            pcall(callback, v)
                            task.wait(0.22)
                            updateFrame()
                        end)
                    end
                end
                buildOptions(list)

                local function toggleDrop()
                    if opened then
                        opened = false
                        tween(Panel, {Size = UDim2.new(1,0,0,0)}, 0.2, Enum.EasingStyle.Quint)
                        tween(Arrow, {Rotation = 0}, 0.2)
                        -- BUG FIX #9: ensure Wrap returns to base height on close
                        task.delay(0.21, function()
                            if not opened then
                                Wrap.Size = UDim2.new(1, 0, 0, 36)
                                updateFrame()
                            end
                        end)
                    else
                        opened = true
                        local h = PanelList.AbsoluteContentSize.Y + 8
                        tween(Panel, {Size = UDim2.new(1,0,0,h)}, 0.25, Enum.EasingStyle.Quint)
                        tween(Arrow, {Rotation = 180}, 0.2)
                        Wrap.Size = UDim2.new(1, 0, 0, 36 + h + 4)
                        task.wait(0.27)
                        updateFrame()
                    end
                end

                el.MouseButton1Click:Connect(toggleDrop)

                if tip ~= "" then
                    el.MouseEnter:Connect(function() showTooltip(tip) end)
                    el.MouseLeave:Connect(function() hideTooltip() end)
                end

                task.spawn(function()
                    while task.wait(0.08) do
                        if not guiAlive() then break end
                        el.BackgroundColor3    = theme.Element
                        Panel.BackgroundColor3 = theme.Element
                        lbl.TextColor3         = theme.Text
                        Arrow.TextColor3       = theme.Accent
                    end
                end)

                updateFrame()

                function DropFuncs:Refresh(newList)
                    buildOptions(newList or {})
                    if opened then
                        local h = PanelList.AbsoluteContentSize.Y + 8
                        Panel.Size = UDim2.new(1, 0, 0, h)
                        Wrap.Size  = UDim2.new(1, 0, 0, 36 + h + 4)
                    end
                    updateFrame()
                end
                return DropFuncs
            end

