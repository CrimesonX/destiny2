                    tween(KeyBadge, {TextColor3 = Color3.fromRGB(255,210,80)}, 0.1)
                    local conn
                    conn = UserInput.InputBegan:Connect(function(inp, processed)
                        if inp.KeyCode ~= Enum.KeyCode.Unknown and not processed then
                            currentKey = inp.KeyCode.Name
                            KeyBadge.Text = currentKey
                            tween(KeyBadge, {TextColor3 = theme.Accent}, 0.15)
                            listening = false
                            conn:Disconnect()
                        end
                    end)
                end)

                UserInput.InputBegan:Connect(function(inp, gp)
                    if not gp and inp.KeyCode.Name == currentKey then
                        pcall(callback)
                    end
                end)

                if tip ~= "" then
                    el.MouseEnter:Connect(function() showTooltip(tip) end)
                    el.MouseLeave:Connect(function() hideTooltip() end)
                end

                task.spawn(function()
                    while task.wait(0.08) do
                        if not guiAlive() then break end
                        el.BackgroundColor3       = theme.Element
                        lbl.TextColor3            = theme.Text
                        KeyBadge.BackgroundColor3 = theme.Header
                    end
                end)

                updateFrame()
            end

            return Elements
        end

        return Sections
    end

    return Tabs
end

return Kavo
