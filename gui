-- ─── Utility: make a UIStroke ─────────────────────────────────────────────────
local function addStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color        = color or Color3.fromRGB(255,255,255)
    s.Thickness    = thickness or 1
    s.Transparency = transparency or 0.88
    s.Parent       = parent
    return s
end

local function addGradient(parent, c0, c1, rotation)
    local g = Instance.new("UIGradient")
    g.Color    = ColorSequence.new(c0, c1)
    g.Rotation = rotation or 90
    g.Parent   = parent
    return g
end

local function addCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function addPadding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 0)
    p.PaddingRight  = UDim.new(0, right  or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft   = UDim.new(0, left   or 0)
    p.Parent = parent
    return p
end

-- BUG FIX #2 & #3: Helper to safely brighten/darken a Color3
-- Color3.R/G/B are in range 0-1, so arithmetic must stay in 0-1
local function shiftColor(c3, delta)
    -- delta is in 0-255 range for convenience, we divide by 255
    local d = delta / 255
    return Color3.new(
        math.clamp(c3.R + d, 0, 1),
        math.clamp(c3.G + d, 0, 1),
        math.clamp(c3.B + d, 0, 1)
    )
end

-- ─── Ripple effect ─────────────────────────────────────────────────────────────
local function ripple(btn, accentColor, ms)
    local sample = Instance.new("Frame")
    sample.AnchorPoint           = Vector2.new(0.5, 0.5)
    sample.BackgroundColor3      = accentColor
    sample.BackgroundTransparency = 0.72
    sample.BorderSizePixel       = 0
    addCorner(sample, 999)
    sample.Parent = btn
    sample.ZIndex = btn.ZIndex + 10
    local x = ms.X - btn.AbsolutePosition.X
    local y = ms.Y - btn.AbsolutePosition.Y
    sample.Position = UDim2.new(0, x, 0, y)
    sample.Size     = UDim2.new(0, 0, 0, 0)
    local size = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.2
    tween(sample, {
        Size = UDim2.new(0, size, 0, size),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1,
    }, 0.5, Enum.EasingStyle.Quint)
    game:GetService("Debris"):AddItem(sample, 0.55)
end

-- ─── Hover effect ─────────────────────────────────────────────────────────────
-- BUG FIX #3: was doing `theme.Element.R*255+12` which double-scaled R (0-1)*255
-- Correct: use shiftColor helper
local function hoverEffect(btn, theme, hovColor)
    local hov = hovColor or shiftColor(theme.Element, 12)
    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundColor3 = hov}, 0.15, Enum.EasingStyle.Sine)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundColor3 = theme.Element}, 0.2, Enum.EasingStyle.Sine)
    end)
end

