                ValLabel.Size                 = UDim2.new(0, 44, 0.55, 0)
                ValLabel.Font                 = Enum.Font.GothamBold
                ValLabel.Text                 = tostring(default)
                ValLabel.TextColor3           = theme.Accent
                ValLabel.TextSize             = 13
                ValLabel.TextXAlignment       = Enum.TextXAlignment.Right

                local Track = Instance.new("Frame")
                Track.Parent           = el
                Track.BackgroundColor3 = theme.Border
                Track.BorderSizePixel  = 0
                Track.Position         = UDim2.new(0, 36, 1, -14)
                Track.Size             = UDim2.new(1, -44, 0, 5)
                addCorner(Track, 99)

                local Fill = Instance.new("Frame")
                Fill.Parent           = Track
                Fill.BackgroundColor3 = theme.Accent
                Fill.BorderSizePixel  = 0
                Fill.Size             = UDim2.new(0, 0, 1, 0)
                addCorner(Fill, 99)
                -- BUG FIX #5: use shiftColor
                addGradient(Fill, shiftColor(theme.Accent, 30), theme.Accent, 0)

                local Thumb = Instance.new("Frame")
                Thumb.Parent           = Track
                Thumb.AnchorPoint      = Vector2.new(0.5, 0.5)
                Thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
                Thumb.BorderSizePixel  = 0
                Thumb.Position         = UDim2.new(0, 0, 0.5, 0)
                Thumb.Size             = UDim2.new(0, 14, 0, 14)
                addCorner(Thumb, 99)
                addStroke(Thumb, theme.Accent, 2, 0.0)
                Thumb.ZIndex = 5

                local function setSlider(pct)
                    pct = math.clamp(pct, 0, 1)
                    local val = math.floor(minV + (maxV - minV) * pct)
                    tween(Fill,  {Size = UDim2.new(pct, 0, 1, 0)}, 0.06, Enum.EasingStyle.Linear)
                    tween(Thumb, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.06, Enum.EasingStyle.Linear)
                    ValLabel.Text = tostring(val)
                    pcall(callback, val)
                end

                task.defer(function()
                    setSlider((default - minV) / math.max(maxV - minV, 1))
                end)

                -- BUG FIX #7: was using Mouse.Move which leaks connections.
                -- Use UserInput.InputChanged instead, disconnect when not dragging.
                local draggingSlider = false

                Track.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        local pct = (inp.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X
                        setSlider(pct)
                    end
                end)
                UserInput.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end)
                UserInput.InputChanged:Connect(function(inp)
                    if draggingSlider and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        local pct = (inp.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X
                        setSlider(pct)
                    end
                end)

                if tip ~= "" then
                    el.MouseEnter:Connect(function() showTooltip(tip) end)
                    el.MouseLeave:Connect(function() hideTooltip() end)
                end

                task.spawn(function()
                    while task.wait(0.08) do
                        if not guiAlive() then break end
                        el.BackgroundColor3    = theme.Element
                        lbl.TextColor3         = theme.Text
                        ValLabel.TextColor3    = theme.Accent
                        Track.BackgroundColor3 = theme.Border
                        Fill.BackgroundColor3  = theme.Accent
                    end
                end)

                updateFrame()
            end

