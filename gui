--// Kavo UI Library — Stable Fixed Edition

local Kavo = {}

local TweenService = game:GetService("TweenService")
local UserInput = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LibName = "destiny"

-- ─── Tween ─────────────────────────
local function tween(obj, props, t, style, dir)
	style = style or Enum.EasingStyle.Quint
	dir = dir or Enum.EasingDirection.Out
	TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

-- ─── Color Safe ─────────────────────
local function shiftColor(c3, delta)
	local d = delta / 255
	return Color3.new(
		math.clamp(c3.R + d, 0, 1),
		math.clamp(c3.G + d, 0, 1),
		math.clamp(c3.B + d, 0, 1)
	)
end

-- ─── Ripple FIX (ไม่ใช้ GetMouse) ───
local function ripple(btn, color, pos)
	local r = Instance.new("Frame")
	r.AnchorPoint = Vector2.new(0.5,0.5)
	r.BackgroundColor3 = color
	r.BackgroundTransparency = 0.7
	r.Size = UDim2.new(0,0,0,0)
	r.Position = UDim2.new(0,pos.X-btn.AbsolutePosition.X,0,pos.Y-btn.AbsolutePosition.Y)
	r.Parent = btn

	local size = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y)*2
	tween(r,{
		Size = UDim2.new(0,size,0,size),
		Position = UDim2.new(0.5,0,0.5,0),
		BackgroundTransparency = 1
	},0.4)

	game:GetService("Debris"):AddItem(r,0.5)
end

-- ─── Dragging ──────────────────────
function Kavo:DraggingEnabled(handle, parent)
	parent = parent or handle

	local dragging = false
	local mousePos, framePos

	handle.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			mousePos = inp.Position
			framePos = parent.Position
		end
	end)

	UserInput.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UserInput.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = inp.Position - mousePos
			parent.Position = UDim2.new(
				framePos.X.Scale,
				framePos.X.Offset + delta.X,
				framePos.Y.Scale,
				framePos.Y.Offset + delta.Y
			)
		end
	end)
end

-- ─── Theme ─────────────────────────
local Theme = {
	Accent = Color3.fromRGB(99,130,210),
	Background = Color3.fromRGB(22,23,28),
	Element = Color3.fromRGB(30,31,38),
	Text = Color3.fromRGB(220,222,235),
	Border = Color3.fromRGB(40,42,52),
}

-- ═══════════════════════════════
function Kavo.CreateLib(name)
	name = name or "Kavo UI"

	-- ลบของเก่า
	for _,v in pairs(game.CoreGui:GetChildren()) do
		if v.Name == LibName then
			v:Destroy()
		end
	end

	local gui = Instance.new("ScreenGui",game.CoreGui)
	gui.Name = LibName

	local main = Instance.new("Frame",gui)
	main.Size = UDim2.new(0,500,0,300)
	main.Position = UDim2.new(0.5,-250,0.5,-150)
	main.BackgroundColor3 = Theme.Background
	main.BorderSizePixel = 0

	Kavo:DraggingEnabled(main)

	-- ปุ่ม
	local function createButton(text,callback)
		local btn = Instance.new("TextButton",main)
		btn.Size = UDim2.new(0,200,0,40)
		btn.Position = UDim2.new(0,20,0,20)
		btn.Text = text
		btn.BackgroundColor3 = Theme.Element
		btn.TextColor3 = Theme.Text
		btn.AutoButtonColor = false

		-- hover
		btn.MouseEnter:Connect(function()
			tween(btn,{BackgroundColor3 = shiftColor(Theme.Element,15)},0.15)
		end)
		btn.MouseLeave:Connect(function()
			tween(btn,{BackgroundColor3 = Theme.Element},0.15)
		end)

		-- ✅ FIX: กัน spam
		local busy = false

		btn.MouseButton1Click:Connect(function()
			if busy then return end
			busy = true

			local m = UserInput:GetMouseLocation()
			ripple(btn,Theme.Accent,Vector2.new(m.X,m.Y))

			pcall(callback)

			task.delay(0.2,function()
				busy = false
			end)
		end)
	end

	-- slider (FIX memory leak)
	local function createSlider()
		local bar = Instance.new("Frame",main)
		bar.Size = UDim2.new(0,200,0,5)
		bar.Position = UDim2.new(0,20,0,80)
		bar.BackgroundColor3 = Theme.Border

		local fill = Instance.new("Frame",bar)
		fill.Size = UDim2.new(0.5,0,1,0)
		fill.BackgroundColor3 = Theme.Accent

		local dragging = false
		local moveConn, endConn

		bar.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true

				if moveConn then moveConn:Disconnect() end
				if endConn then endConn:Disconnect() end

				moveConn = UserInput.InputChanged:Connect(function(i)
					if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
						local pct = (i.Position.X - bar.AbsolutePosition.X)/bar.AbsoluteSize.X
						fill.Size = UDim2.new(math.clamp(pct,0,1),0,1,0)
					end
				end)

				endConn = UserInput.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = false
						moveConn:Disconnect()
						endConn:Disconnect()
					end
				end)
			end
		end)
	end

	-- test
	createButton("Click me",function()
		print("clicked")
	end)

	createSlider()

	return Kavo
end

return Kavo
