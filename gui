        TabBtn.TextSize             = 13.5
        TabBtn.TextXAlignment       = Enum.TextXAlignment.Left
        TabBtn.BorderSizePixel      = 0
        addCorner(TabBtn, 7)
        addPadding(TabBtn, 0, 0, 0, 6)

